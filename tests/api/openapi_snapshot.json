{
  "components": {
    "schemas": {
      "ErrorDetail": {
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "title": "Details",
            "type": "object"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "request_id": {
            "title": "Request Id",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "request_id"
        ],
        "title": "ErrorDetail",
        "type": "object"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "required": [
          "error"
        ],
        "title": "ErrorResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ReadyResponse": {
        "properties": {
          "ready": {
            "title": "Ready",
            "type": "boolean"
          },
          "services": {
            "$ref": "#/components/schemas/ServiceHealth"
          }
        },
        "required": [
          "ready",
          "services"
        ],
        "title": "ReadyResponse",
        "type": "object"
      },
      "ServiceHealth": {
        "description": "DEC-117 full-dependency health check, per specs/06-api-contracts.md's\nAPI-O-01 contract. No real health checks exist yet (Phase 1) \u2014 every\nfield defaults to False rather than being silently omitted, so /ready's\nshape is already correct even though its values aren't wired to\nanything real yet.",
        "properties": {
          "nli": {
            "default": false,
            "title": "Nli",
            "type": "boolean"
          },
          "policy": {
            "default": false,
            "title": "Policy",
            "type": "boolean"
          },
          "postgres": {
            "default": false,
            "title": "Postgres",
            "type": "boolean"
          },
          "qdrant": {
            "default": false,
            "title": "Qdrant",
            "type": "boolean"
          },
          "redis": {
            "default": false,
            "title": "Redis",
            "type": "boolean"
          },
          "safety_input": {
            "default": false,
            "title": "Safety Input",
            "type": "boolean"
          },
          "safety_output": {
            "default": false,
            "title": "Safety Output",
            "type": "boolean"
          },
          "tei_embed": {
            "default": false,
            "title": "Tei Embed",
            "type": "boolean"
          },
          "tei_rerank": {
            "default": false,
            "title": "Tei Rerank",
            "type": "boolean"
          },
          "vllm": {
            "default": false,
            "title": "Vllm",
            "type": "boolean"
          }
        },
        "title": "ServiceHealth",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
