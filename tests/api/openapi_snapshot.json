  },
  "info": {
    "title": "FastAPI",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/ready": {
      "get": {
        "description": "Report aggregate readiness. Always returns 200 (per API-O-01) \u2014 a\nhealth-check endpoint returning 5xx during startup would be\nindistinguishable from \"the endpoint itself is broken\".",
        "operationId": "get_ready_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Ready"
      }
    },
    "/v1/query": {
      "post": {
        "description": "Registered and auth-enforced; returns 501 until Phase 3 wires the\nreal query graph (specs/10-build-plan.md TASK-033's own text: \"returns\n501 until Phase 3 lands\" -- deliberate and temporary, not an unresolved\nplaceholder). `06-api-contracts.md`'s Error Schema table doesn't list\n501 among its documented codes -- flagged as an update-specs candidate,\nnot something to hand-fix here -- so this still returns the same\nstructured error shape every other non-2xx response uses, rather than a\nbare, bodyless 501.",
        "operationId": "post_query_v1_query_post",
        "parameters": [
          {
            "in": "header",
            "name": "authorization",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          },
          {
            "in": "header",
            "name": "X-Admin-Api-Key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Admin-Api-Key"
            }
          }
        ],
        "responses": {
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid credentials"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "501": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Not implemented until Phase 3"
          }
        },
        "summary": "Post Query"
      }
    }
  }
}
